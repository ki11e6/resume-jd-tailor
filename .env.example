# Use Google AI Studio (free tier) rather than Vertex AI
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=your_api_key_here

# Optional: Groq (free tier) for the "groq" / "auto" provider. Get one at
# https://console.groq.com/keys — only needed if you use the Groq engine.
GROQ_API_KEY=your_groq_key_here
